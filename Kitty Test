-- [[ 3. ฟังก์ชันสร้าง ESP รูปแบบใหม่ (รองรับ Box, Name, Distance) ]]
-- ==========================================================
local function CreateESP(target, color, espName, displayText)
    if not target or not target.Parent then return end

    pcall(function()
        -- จัดการความโปร่งใส (เหมือนเดิม)
        local function HandleTransparency(part)
            if part:IsA("BasePart") then
                if part.Name == "HumanoidRootPart" then return end
                if part.Name == "Handle" and part.Transparency >= 1 then return end
                if part.Transparency >= 1 then
                    local ancestorModel = part:FindFirstAncestorWhichIsA("Model")
                    if ancestorModel and ancestorModel:FindFirstChildOfClass("Humanoid") then return end
                end

                if part:GetAttribute("OrigTrans_" .. espName) == nil then
                    part:SetAttribute("OrigTrans_" .. espName, part.Transparency)
                end
                part.Transparency = 0 
            end
        end

        if espName == "ESP_Puzzle" then
            if target:IsA("BasePart") then HandleTransparency(target)
            elseif target:IsA("Model") then
                for _, v in ipairs(target:GetDescendants()) do HandleTransparency(v) end
            end
        end

        -- 🔴 1. Highlight ESP (อิงตาม Toggle)
        local hl = target:FindFirstChild(espName .. "_HL") or Instance.new("Highlight")
        hl.Name = espName .. "_HL"
        hl.FillColor = color
        hl.FillTransparency = 0.5
        hl.OutlineColor = color
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = HighlightToggle.Value
        hl.Parent = target

        -- หาจุดศูนย์กลาง
        local root = target:IsA("Model") and (target.PrimaryPart or target:FindFirstChild("Head") or target:FindFirstChildWhichIsA("BasePart", true)) or (target:IsA("BasePart") and target)

        if root then
            -- 🟢 คำนวณระยะทาง
            local dist = 0
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude)
            end

            -- 🟢 จัดการข้อความ (Name + Distance)
            local finalText = ""
            if NameToggle.Value then finalText = displayText or target.Name end
            if DistanceToggle.Value then
                if finalText ~= "" then
                    finalText = finalText .. " [" .. tostring(dist) .. "m]"
                else
                    finalText = "[" .. tostring(dist) .. "m]"
                end
            end

            -- 🟡 2. Text ESP
            local bg = root:FindFirstChild(espName .. "_BG") or Instance.new("BillboardGui")
            bg.Name = espName .. "_BG"
            bg.Size = UDim2.new(0, 200, 0, 40)
            bg.AlwaysOnTop = true
            bg.ExtentsOffset = Vector3.new(0, 3, 0) -- ลอยเหนือเป้าหมายเล็กน้อย

            local txt = bg:FindFirstChild("NameLabel") or Instance.new("TextLabel")
            txt.Name = "NameLabel"
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Text = finalText
            txt.TextColor3 = color
            txt.Font = Enum.Font.SourceSansBold
            txt.TextSize = 14
            txt.TextStrokeTransparency = 0
            txt.Visible = (NameToggle.Value or DistanceToggle.Value) -- ปิดถ้าไม่ได้เปิดสักอัน
            txt.Parent = bg
            bg.Parent = root

            -- 🟦 3. Box ESP
            local boxBg = root:FindFirstChild(espName .. "_BoxBG") or Instance.new("BillboardGui")
            boxBg.Name = espName .. "_BoxBG"
            -- ปรับขนาดกล่องให้เหมาะกับ คน หรือ สิ่งของ
            boxBg.Size = (espName == "ESP_Player") and UDim2.new(4, 0, 5.5, 0) or UDim2.new(2, 0, 2, 0)
            boxBg.AlwaysOnTop = true
            boxBg.ExtentsOffset = Vector3.new(0, 0, 0) -- ให้อยู่กลางลำตัว
            boxBg.Enabled = BoxToggle.Value

            local boxFrame = boxBg:FindFirstChild("BoxFrame") or Instance.new("Frame")
            boxFrame.Name = "BoxFrame"
            boxFrame.Size = UDim2.new(1, 0, 1, 0)
            boxFrame.BackgroundTransparency = 1
            boxFrame.Parent = boxBg

            -- ใช้ UIStroke ตีเส้นกรอบ
            local stroke = boxFrame:FindFirstChild("UIStroke") or Instance.new("UIStroke")
            stroke.Color = color
            stroke.Thickness = 1.5
            stroke.Parent = boxFrame

            boxBg.Parent = root
        end
    end)
end

