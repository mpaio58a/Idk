-- Puzzle ESP
task.spawn(function()
    local validStatuses = {["PuzzlePut"] = true, ["PuzzleLocked"] = true, ["RecipePuzzle"] = true, ["PuzzleExtractor"] = true, ["PuzzleInfinite"] = true}
    local valueConnections = {}

    local function RemoveSpecificESP(model, espName)
        pcall(function()
            if model:FindFirstChild(espName .. "_HL") then model[espName .. "_HL"]:Destroy() end
            local root = model:IsA("Model") and (model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)) or model
            if root and root:FindFirstChild(espName .. "_BG") then root[espName .. "_BG"]:Destroy() end
            if root and root:FindFirstChild(espName .. "_BoxBG") then root[espName .. "_BoxBG"]:Destroy() end

            local function RestoreTrans(part)
                if part:IsA("BasePart") then
                    local orig = part:GetAttribute("OrigTrans_" .. espName)
                    if orig then
                        part.Transparency = orig
                        part:SetAttribute("OrigTrans_" .. espName, nil)
                    end
                end
            end

            if model:IsA("BasePart") then RestoreTrans(model)
            elseif model:IsA("Model") then
                for _, p in ipairs(model:GetDescendants()) do RestoreTrans(p) end
            end
        end)
    end

    while true do
        if PuzzleEspToggle.Value then
            pcall(function()
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if not PuzzleEspToggle.Value then break end
                    if obj:IsA("StringValue") and obj.Name == "Status" then
                        local model = obj:FindFirstAncestorWhichIsA("Model") or obj.Parent
                        if model and (model:IsA("Model") or model:IsA("BasePart")) then
                            if validStatuses[obj.Value] then
                                CreateESP(model, PuzzleColor.Value, "ESP_Puzzle", model.Name)
                                if not valueConnections[obj] then
                                    valueConnections[obj] = obj:GetPropertyChangedSignal("Value"):Connect(function()
                                        if not validStatuses[obj.Value] or not PuzzleEspToggle.Value then
                                            RemoveSpecificESP(model, "ESP_Puzzle")
                                            if valueConnections[obj] then
                                                valueConnections[obj]:Disconnect()
                                                valueConnections[obj] = nil
                                            end
                                        end
                                    end)
                                end
                            else
                                RemoveSpecificESP(model, "ESP_Puzzle")
                            end
                        end
                    end
                end
            end)
        end
        task.wait(1.5)
    end
end)