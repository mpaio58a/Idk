local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")
local MarketplaceService = game:GetService("MarketplaceService")

local player = Players.LocalPlayer
local webhookUrl = "https://discord.com/api/webhooks/1507838706835394603/RdJVYJojSjFkIBpfS9qcpnwsmRyd_ixYZTzGsBCRC10l08x6cTEqDcVqq1s-PLuCtEFD"
local uniqueNamespace = "track_project_x_2026"
local countKey = "total_executes"

local requestFunc = request or http_request or (http and http.request) or syn.request or (fluxus and fluxus.request) or (Krnl and Krnl.request)

local function getDevice()
    if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
        return GuiService:IsTenFootInterface() and "Console" or "Mobile"
    elseif UserInputService.KeyboardEnabled then
        return "Computer"
    else
        return "Unknown"
    end
end

local function getOS()
    local platform = UserInputService:GetPlatform()
    if platform == Enum.Platform.IOS then
        return "iOS"
    elseif platform == Enum.Platform.Android then
        return "Android"
    elseif platform == Enum.Platform.Windows then
        return "Windows"
    elseif platform == Enum.Platform.OSX then
        return "macOS"
    end
    return "Other"
end

local function getGameName()
    local success, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roproxy.com/v1/games?placeIds=" .. game.PlaceId))
    end)
    if success and response and response.data and response.data[1] then
        return response.data[1].name
    end
    local productSuccess, productInfo = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId)
    end)
    return productSuccess and productInfo.Name or "Unknown Game"
end

local globalCount = "Error"
if requestFunc then
    local apiSuccess, res = pcall(function()
        return requestFunc({
            Url = "https://api.counterapi.dev/v1/" .. uniqueNamespace .. "/" .. countKey .. "/up",
            Method = "GET"
        })
    end)
    if apiSuccess and res and res.Body then
        local decodeSuccess, decoded = pcall(function()
            return HttpService:JSONDecode(res.Body)
        end)
        if decodeSuccess and decoded.count then
            globalCount = tostring(decoded.count)
        end
    end
end

