local ToolList = {}
local ToolNames = {"Press Refresh"}

-- ตัวแปรเก็บค่าจาก Dropdown (Mspaint Library ส่วนใหญ่ใช้ตารางรับค่า)
local selectedItem = nil 

MiscTab:CreateDropdown("Teleport to Item", ToolNames, function(value)
    selectedItem = value
end)

MiscTab:CreateButton("🔄 Refresh Items (Show All)", function()
    ToolList = {}
    ToolNames = {}
    local nameCount = {}
    local tf = GetTargetFolder("Tools") or GetTargetFolder("Items")
    if tf then
        for _, v in ipairs(tf:GetChildren()) do
            if v:IsA("Model") or v:IsA("Tool") or v:IsA("BasePart") then
                local oName = v.Name
                nameCount[oName] = (nameCount[oName] or 0) + 1
                local dName = oName .. " [" .. tostring(nameCount[oName]) .. "]"
                table.insert(ToolNames, dName)
                ToolList[dName] = v
            end
        end
    end
    table.sort(ToolNames)
    
    -- ข้อสังเกต: Library บางตัวต้องสร้างปุ่มใหม่ หรือมีคำสั่ง UpdateDropdown
    -- แต่เราสามารถใช้แจ้งเตือนให้ผู้เล่นกดเลือกใหม่ได้
    print("Items Refreshed! Found: " .. #ToolNames)
end)

MiscTab:CreateButton("⚡ Teleport (Go to Selected)", function()
    if selectedItem then
        local target = ToolList[selectedItem]
        if target and game.Players.LocalPlayer.Character then
            local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local pos = target:IsA("Model") and (target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")) or target
            if hrp and pos then 
                hrp.CFrame = pos.CFrame + Vector3.new(0, 3, 0) 
            end
        end
    end
end)

MiscTab:CreateToggle("Anti Trap", function(state)
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "Center" and v.Parent.Name:lower():find("trap") then
            v.CanTouch = not state
            v.Transparency = state and 0.8 or 0
        end
    end
end)

