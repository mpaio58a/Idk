MainTab:CreateSlider("WalkSpeed", 16, 100, function(value)
    pcall(function() game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = value end)
end)

local autoSpamEnabled = false
MainTab:CreateToggle("Auto Spam Everything", function(state)
    autoSpamEnabled = state
end)

task.spawn(function()
    local interactRemote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Interact")
    while true do
        if autoSpamEnabled then
            pcall(function()
                local map = workspace:FindFirstChild("Map")
                if map then
                    for _, room in pairs(map:GetChildren()) do
                        local int = room:FindFirstChild("Interacts")
                        if int then 
                            for _, o in pairs(int:GetChildren()) do 
                                if not autoSpamEnabled then break end 
                                interactRemote:FireServer(o) 
                            end 
                        end
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

