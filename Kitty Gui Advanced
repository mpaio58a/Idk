    end)
    
    while true do
        -- เช็คทั้งตัวแปร success และค่า Toggle
        if success and AutoSpamToggle.Value then
            pcall(function()
                local map = workspace:FindFirstChild("Map")
                if map then
                    -- วนหา Interacts ทุกห้อง
                    for _, room in pairs(map:GetChildren()) do
                        local interacts = room:FindFirstChild("Interacts")
                        if interacts then
                            for _, obj in pairs(interacts:GetChildren()) do
                                -- ถ้ากดปิดปุ่ม ให้หยุดวนลูปทันที
                                if not AutoSpamToggle.Value then break end
                                interactRemote:FireServer(obj)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.5) -- ความเร็วมาตรฐาน ไม่ทำให้เครื่องค้าง
    end
end)

    -- Anti Trap Toggle (Updated with Hide/Restore Logic)
    local AntiTrapToggle = Tabs.Misc:AddToggle("AntiTrap", {
        Title = "Anti Trap", 
        Description = "Walking into traps will have no effect while this script is enabled.", 
        Default = false 
    })

local AntiTrapConnection -- ประกาศไว้ข้างบน OnChanged

AntiTrapToggle:OnChanged(function()
    if AntiTrapToggle.Value then
        -- 1. จัดการของเก่าที่มีอยู่แล้ว
        local function DisableTrap(obj)
            if obj:IsA("BasePart") and obj.Name == "Center" and obj.Parent and obj.Parent.Name:lower():find("trap") then
                obj.CanTouch = false
                obj.Transparency = 1 
            end
        end

        for _, v in pairs(workspace:GetDescendants()) do
            DisableTrap(v)
        end

        -- 2. ดักจับของใหม่ที่เกิดมาระหว่างเกม (วางแทนที่อันเก่าได้เลย)
        AntiTrapConnection = workspace.DescendantAdded:Connect(function(descendant)
            if AntiTrapToggle.Value then
                task.wait(0.2) -- รอให้โมเดลโหลดเสร็จ
                DisableTrap(descendant)
            end
        end)
    else
        -- 3. คืนค่าเมื่อปิดปุ่ม
        if AntiTrapConnection then AntiTrapConnection:Disconnect() end
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Name == "Center" and v.Parent and v.Parent.Name:lower():find("trap") then
                v.CanTouch = true
                v.Transparency = 1 
            end
        end
    end
    end)

