local FolderCache = {}
local function GetTargetFolder(name)
    if FolderCache[name] and FolderCache[name].Parent then return FolderCache[name] end
    local f = workspace:FindFirstChild(name) or (workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild(name))
    if not f then f = workspace:FindFirstChild(name, true) end
    FolderCache[name] = f
    return f
end

local function CreateESP(target, color, espName, displayText)
    if not target then return end
    local hl = target:FindFirstChild(espName .. "_HL")
    if not hl then
        hl = Instance.new("Highlight", target)
        hl.Name = espName .. "_HL"
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    end
    hl.FillColor = color

    local attachPart = target:IsA("Model") and (target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Head") or target.PrimaryPart) or target
    if attachPart and attachPart:IsA("BasePart") then
        local bg = attachPart:FindFirstChild(espName .. "_BG")
        if not bg then
            bg = Instance.new("BillboardGui", attachPart)
            bg.Name = espName .. "_BG"
            bg.Size = UDim2.new(0, 100, 0, 40)
            bg.AlwaysOnTop = true
            bg.ExtentsOffset = Vector3.new(0, 3, 0)

            local txt = Instance.new("TextLabel", bg)
            txt.Name = "NameLabel"
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Font = Enum.Font.SourceSansBold
            txt.TextSize = 14
            txt.TextStrokeTransparency = 0
            txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        end
        local txt = bg:FindFirstChild("NameLabel")
        if txt then
            txt.Text = displayText or target.Name
            txt.TextColor3 = color
        end
    end
end

task.spawn(function()
    while task.wait(1) do
        if espPlayerEnabled then
            pcall(function()
                for _, plr in ipairs(game.Players:GetPlayers()) do
                    if plr.Character and plr ~= game.Players.LocalPlayer then
                        local isKiller = plr.Character:FindFirstChild("Weapon", true)
                        CreateESP(plr.Character, isKiller and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0), "ESP_Player", plr.Name)
                    end
                end
                local pFolder = GetTargetFolder("Players")
                if pFolder then
                    for _, bot in ipairs(pFolder:GetChildren()) do
                        if bot:IsA("Model") and bot ~= game.Players.LocalPlayer.Character then
                            local isKiller = bot:FindFirstChild("Weapon", true)
                            CreateESP(bot, isKiller and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0), "ESP_Player", bot.Name)
                        end
                    end
                end
            end)
        end
        if espItemEnabled then
            pcall(function()
                local tFolder = GetTargetFolder("Tools") or GetTargetFolder("Items")
                if tFolder then
                    for _, i in ipairs(tFolder:GetChildren()) do
                        if i:IsA("Model") or i:IsA("Tool") or i:IsA("BasePart") then
                            CreateESP(i, Color3.fromRGB(255,255,255), "ESP_Item", i.Name)
                        end
                    end
                end
            end)
        end
        if espTrapEnabled then
            pcall(function()
                local trFolder = GetTargetFolder("Traps")
                if trFolder then
                    for _, t in ipairs(trFolder:GetChildren()) do
                        if t:IsA("Model") or t:IsA("BasePart") then CreateESP(t, Color3.fromRGB(255,255,0), "ESP_Trap", "Trap") end
                    end
                end
            end)
        end
    end
end)

