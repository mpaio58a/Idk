-- ==========================================================
-- 👁️ ฟังก์ชัน CreateESP (เวอร์ชัน: ซ่อน Hitbox ล่องหนในตัวผู้เล่น)
-- ==========================================================
local function CreateESP(target, color, espName, displayText)
    if not target or not target.Parent then return end

    pcall(function()
        -- [[ 🟢 ระบบจัดการความโปร่งใส (ฉลาดขึ้น ไม่ยุ่งกับของล่องหนในตัวคน) ]]
        local function HandleTransparency(part)
            if part:IsA("BasePart") then

                -- ข้อยกเว้นที่ 1: ห้ามยุ่งกับ HumanoidRootPart
                if part.Name == "HumanoidRootPart" then return end

                -- ข้อยกเว้นที่ 2: ห้ามยุ่งกับ Handle ที่เกมสั่งให้ล่องหน
                if part.Name == "Handle" and part.Transparency >= 1 then return end

                -- 🔥 ข้อยกเว้นที่ 3 (ใหม่ล่าสุด): ห้ามยุ่งกับ Part ล่องหนที่อยู่ในตัวละคร!
                if part.Transparency >= 1 then
                    -- เช็คว่าชิ้นส่วนนี้อยู่ใน Model ที่มี Humanoid (ผู้เล่นหรือบอท) หรือไม่
                    local ancestorModel = part:FindFirstAncestorWhichIsA("Model")
                    if ancestorModel and ancestorModel:FindFirstChildOfClass("Humanoid") then
                        return -- ถ้าใช่ ปล่อยให้มันล่องหนต่อไป ไม่ต้องไปบังคับทึบแสง!
                    end
                end

                -- ถ้าหลุดรอดข้อยกเว้นมาได้ ค่อยฝังชิปความจำและบังคับทึบแสง
                if part:GetAttribute("OrigTrans_" .. espName) == nil then
                    part:SetAttribute("OrigTrans_" .. espName, part.Transparency)
                end
                part.Transparency = 0 
            end
        end

        -- นำระบบจัดการความโปร่งใสไปใช้กับเป้าหมาย
        if target:IsA("BasePart") then
            HandleTransparency(target)
        elseif target:IsA("Model") then
            for _, v in ipairs(target:GetDescendants()) do
                HandleTransparency(v)
            end
        end

        -- [[ 🔴 สร้าง Highlight (เกาะเฉพาะชิ้นส่วนที่มองเห็น) ]]
        local hl = target:FindFirstChild(espName .. "_HL") or Instance.new("Highlight")
        hl.Name = espName .. "_HL"
        hl.FillColor = color
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = target

        -- [[ 🟡 สร้างป้ายชื่อ ]]
        local root = target:IsA("Model") and (target.PrimaryPart or target:FindFirstChild("Head") or target:FindFirstChildWhichIsA("BasePart", true)) or (target:IsA("BasePart") and target)

        if root then
            local bg = root:FindFirstChild(espName .. "_BG") or Instance.new("BillboardGui")
            bg.Name = espName .. "_BG"
            bg.Size = UDim2.new(0, 100, 0, 40)
            bg.AlwaysOnTop = true
            bg.ExtentsOffset = Vector3.new(0, 3, 0)

            local txt = bg:FindFirstChild("NameLabel") or Instance.new("TextLabel")
            txt.Name = "NameLabel"
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.Text = displayText or target.Name
            txt.TextColor3 = color
            txt.Font = Enum.Font.SourceSansBold
            txt.TextSize = 14
            txt.TextStrokeTransparency = 0
            txt.Parent = bg
            bg.Parent = root
        end
    end)
end

-- [[ 3. ระบบลบ ESP (แก้แลค: ทำงานแค่ตอนกดปิด) ]]
local function RemoveESP(espName)
    pcall(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            -- ลบ Highlight และ ป้ายชื่อ
            if v.Name == (espName .. "_HL") or v.Name == (espName .. "_BG") then
                v:Destroy()
            end

            -- ถอดชิปความจำและคืนค่าความโปร่งใสเดิม
            if v:IsA("BasePart") then
                local origTrans = v:GetAttribute("OrigTrans_" .. espName)
                if origTrans ~= nil then
                    v.Transparency = origTrans
                    v:SetAttribute("OrigTrans_" .. espName, nil)
                end
            end
        end
    end)
end

