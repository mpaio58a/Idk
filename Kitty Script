        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Hum = Character and Character:FindFirstChildOfClass("Humanoid")
        
        -- 🔍 ค้นหา BOT
        local Bot = nil
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name == "BOT" and v:IsA("Model") then Bot = v break end
        end

        if not Bot or not Root or not Hum then
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "Error",
                Text = "Not Found Bot",
                Duration = 3
            })
            return 
        end

        -- 🎯 ล็อคเป้าหมาย (ใช้ RootPart เพื่อความแม่นยำของทิศทาง)
        local BotRoot = Bot:FindFirstChild("HumanoidRootPart") or Bot:FindFirstChild("LowerTorso")

        task.spawn(function()
            local OldPos = Root.CFrame
            local OldFPDH = workspace.FallenPartsDestroyHeight
            workspace.FallenPartsDestroyHeight = 0/0 

            workspace.CurrentCamera.CameraSubject = BotRoot

            -- 🌀 ปรับฟิสิกส์ 100X
            Hum.PlatformStand = true
            local BV = Instance.new("BodyVelocity")
            BV.Parent = Root
            BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            BV.Velocity = Vector3.new(9e18, 9e18, 9e18)

            local StartTime = tick()
            local Connection
            
            Connection = game:GetService("RunService").Heartbeat:Connect(function()
                if tick() - StartTime > 3 or not Bot.Parent or not Character.Parent then
                    if Connection then Connection:Disconnect() end
                    return
                end
                
                -- Noclip ทะลุ 100%
                for _, part in pairs(Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end

                -- มุมหมุนพายุ 100X แบบ Chaos
                local ChaosRot = CFrame.Angles(
                    math.rad(math.random(-36000, 36000)), 
                    math.rad(math.random(-36000, 36000)), 
                    math.rad(math.random(-36000, 36000))
                )
                
                -- 🔥 จุดเปลี่ยน: ดักหน้า (แกน Z ติดลบ)
                local FrontOffset = CFrame.new(
                    math.random(-5, 5) / 10,  
                    math.random(-5, 5) / 10,  
                    -5  -- เปลี่ยนเป็น -5 เพื่อให้พายุไปดักอยู่ "ด้านหน้า" ของ BOT
                )
                
                -- วาร์ปดักหน้าตลอดเวลา
                Root.CFrame = BotRoot.CFrame * FrontOffset * ChaosRot
                
                -- ยัดแรงฟิสิกส์สะบัดระดับ 100X
                Root.AssemblyLinearVelocity = Vector3.new(9e18, 9e18, 9e18)
                Root.AssemblyAngularVelocity = Vector3.new(9e18, 9e18, 9e18)
            end)

            task.wait(3.1)

            -- 🧹 Cleanup ล้างค่าเพื่อให้กดซ้ำได้
            if Connection then Connection:Disconnect() end
            if BV then BV:Destroy() end
            Hum.PlatformStand = false
            workspace.CurrentCamera.CameraSubject = Hum
            workspace.FallenPartsDestroyHeight = OldFPDH
            
            Root.CFrame = OldPos
            Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            Root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

            -- 🔄 Rejoin
            local RS = game:GetService("ReplicatedStorage")
            local Ev = RS:FindFirstChild("Events")
            if Ev then
                if Ev:FindFirstChild("Leave") then Ev.Leave:FireServer() end
                task.wait(0.1)
                if Ev:FindFirstChild("Join") then Ev.Join:FireServer() end
            end
        end)
    end
})

