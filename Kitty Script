    end })

    -- Anti Trap Toggle (Updated with Hide/Restore Logic)
    local AntiTrapToggle = Tabs.Misc:AddToggle("AntiTrap", {
        Title = "Anti Trap", 
        Description = "Walking into traps will have no effect while this script is enabled.", 
        Default = false 
    })

local AntiTrapConnection -- ประกาศไว้ข้างบน OnChanged

AntiTrapToggle:OnChanged(function()
    if AntiTrapToggle.Value then
        -- 1. จัดการของเก่าที่มีอยู่แล้ว
        local function DisableTrap(obj)
            if obj:IsA("BasePart") and obj.Name == "Center" and obj.Parent and obj.Parent.Name:lower():find("trap") then
                obj.CanTouch = false
                obj.Transparency = 1 
            end
        end

        for _, v in pairs(workspace:GetDescendants()) do
            DisableTrap(v)
        end

        -- 2. ดักจับของใหม่ที่เกิดมาระหว่างเกม (วางแทนที่อันเก่าได้เลย)
        AntiTrapConnection = workspace.DescendantAdded:Connect(function(descendant)
            if AntiTrapToggle.Value then
                task.wait(0.2) -- รอให้โมเดลโหลดเสร็จ
                DisableTrap(descendant)
            end
        end)
    else
        -- 3. คืนค่าเมื่อปิดปุ่ม
        if AntiTrapConnection then AntiTrapConnection:Disconnect() end
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Name == "Center" and v.Parent and v.Parent.Name:lower():find("trap") then
                v.CanTouch = true
                v.Transparency = 1 
            end
        end
    end
    end)

    local AttackToggle = Tabs.Misc:AddToggle("AttackBtnSwitch", {Title = "Show Custom Attack Button", Default = false })
    AttackToggle:OnChanged(function()
        if AttackToggle.Value then
            if not attackGui then
                attackGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
                local btn = Instance.new("TextButton", attackGui)
                local c = Instance.new("UICorner", btn)
                btn.Size = UDim2.new(0, 120, 0, 50)
                btn.Position = UDim2.new(0.5, -60, 0.8, 0)
                btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                btn.Text = "ATTACK"
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.Font = Enum.Font.SourceSansBold
                btn.TextSize = 20
                btn.Draggable = true
                c.CornerRadius = UDim.new(0, 12)
                btn.MouseButton1Click:Connect(function() game:GetService("ReplicatedStorage").Events.Attack:FireServer() end)
            end
            attackGui.Enabled = true
        else
            if attackGui then attackGui.Enabled = false end
        end
    end)
end

