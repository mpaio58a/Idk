-- (Player, Item, Trap ESP Logic)
local function createPlayerESP(char, name, color)
    if not char then return end
    local hl = char:FindFirstChild("P_HL") or Instance.new("Highlight")
    hl.Name = "P_HL"
    hl.Parent = char
    hl.FillColor = color
    hl.FillTransparency = 0.5
    hl.OutlineColor = Color3.new(1, 1, 1)
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
    if root then
        local b = root:FindFirstChild("P_B") or Instance.new("BillboardGui")
        b.Name = "P_B"
        b.Parent = root
        b.Size = UDim2.new(0, 100, 0, 30)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 3, 0)
        local l = b:FindFirstChild("L") or Instance.new("TextLabel")
        l.Name = "L"
        l.Parent = b
        l.Size = UDim2.new(1, 0, 1, 0)
        l.BackgroundTransparency = 1
        l.Text = name
        l.TextColor3 = color
        l.Font = Enum.Font.SourceSansBold
        l.TextSize = 14
        l.TextStrokeTransparency = 0
    end
end

local function applyItemESP(obj)
    if not obj or not obj:IsDescendantOf(workspace) then return end
    local hl = obj:FindFirstChild("I_HL") or Instance.new("Highlight")
    hl.Name = "I_HL"
    hl.Parent = obj
    hl.FillColor = Color3.new(1, 1, 1)
    hl.FillTransparency = 0.5
    local target = obj:FindFirstChild("Handle") or obj:FindFirstChildOfClass("BasePart", true)
    if target then
        local b = target:FindFirstChild("I_B") or Instance.new("BillboardGui")
        b.Name = "I_B"
        b.Parent = target
        b.Size = UDim2.new(0, 150, 0, 50)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 1.5, 0)
        local l = b:FindFirstChild("L") or Instance.new("TextLabel")
        l.Name = "L"
        l.Parent = b
        l.Size = UDim2.new(1, 0, 1, 0)
        l.BackgroundTransparency = 1
        l.Text = obj.Name
        l.TextColor3 = Color3.new(1, 1, 1)
        l.Font = Enum.Font.SourceSansBold
        l.TextSize = 14
        l.TextStrokeTransparency = 0
    end
end

local function applyTrapESP(model)
    if not model or not model:IsA("Model") then return end
    local yellowColor = Color3.fromRGB(255, 255, 0)
    local hl = model:FindFirstChild("T_HL") or Instance.new("Highlight")
    hl.Name = "T_HL"
    hl.Parent = model
    hl.FillColor = yellowColor
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.FillTransparency = 0.5
    local target = model.PrimaryPart or model:FindFirstChildOfClass("BasePart")
    if target then
        local b = target:FindFirstChild("T_B") or Instance.new("BillboardGui")
        b.Name = "T_B"
        b.Parent = target
        b.Size = UDim2.new(0, 100, 0, 40)
        b.AlwaysOnTop = true
        b.ExtentsOffset = Vector3.new(0, 2, 0)
        local l = b:FindFirstChild("L") or Instance.new("TextLabel")
        l.Name = "L"
        l.Parent = b
        l.Size = UDim2.new(1, 0, 1, 0)
        l.BackgroundTransparency = 1
        l.Text = "Trap"
        l.TextColor3 = yellowColor
        l.Font = Enum.Font.SourceSansBold
        l.TextSize = 18
        l.TextStrokeTransparency = 0
    end
end

do
    local PlayerToggle = Tabs.Visual:AddToggle("PlayerEsp", {Title = "Player & Bot Esp", Default = false })
    local ItemToggle = Tabs.Visual:AddToggle("ItemEsp", {Title = "Items Esp", Default = false })
    local TrapToggle = Tabs.Visual:AddToggle("TrapEsp", {Title = "Trap Esp", Default = false })

    PlayerToggle:OnChanged(function()
        _G.PlayerEspEnabled = PlayerToggle.Value
        if not _G.PlayerEspEnabled then
            for _, v in pairs(workspace:GetDescendants()) do if v.Name == "P_HL" or v.Name == "P_B" then v:Destroy() end end
        end
    end)

    ItemToggle:OnChanged(function()
        _G.ItemEspEnabled = ItemToggle.Value
        if not _G.ItemEspEnabled then
            for _, v in pairs(workspace:GetDescendants()) do if v.Name == "I_HL" or v.Name == "I_B" then v:Destroy() end end
        end
    end)

    TrapToggle:OnChanged(function()
        _G.TrapEspEnabled = TrapToggle.Value
        if not _G.TrapEspEnabled then
            for _, v in pairs(workspace:GetDescendants()) do if v.Name == "T_HL" or v.Name == "T_B" then v:Destroy() end end
        end
    end)

    task.spawn(function()
        while true do
            if _G.PlayerEspEnabled then
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") then
                        local char = v.Parent
                        if char and char:IsA("Model") and char ~= game.Players.LocalPlayer.Character then
                            local isKiller = char:FindFirstChild("Weapon", true)
                            createPlayerESP(char, char.Name, isKiller and Color3.new(1, 0, 0) or Color3.new(0, 1, 0))
                        end
                    end
                end
            end
            task.wait(1)
        end
    end)

    task.spawn(function()
        while true do
            if _G.ItemEspEnabled then
                pcall(function()
                    for _, v in pairs(workspace:GetDescendants()) do
                        local isItem = v:IsA("Model") and (v.Name:lower():find("item") or v:FindFirstChild("Handle") or (v.Parent and v.Parent.Name == "Tools")) or v:IsA("Tool")
                        if isItem and not v:FindFirstChild("I_HL") then applyItemESP(v) end
                    end
                end)
            end
            task.wait(3)
        end
    end)

    task.spawn(function()
        while true do
            if _G.TrapEspEnabled then
                pcall(function()
                    for _, obj in pairs(workspace:GetDescendants()) do
                        if obj:IsA("Model") and obj.Name:lower():find("trap") then
                            if not obj:FindFirstChild("T_HL") then applyTrapESP(obj) end
                        end
                    end
                end)
            end
            task.wait(0.5)
        end
    end)
end

