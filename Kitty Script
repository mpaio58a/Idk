-- ⚪ ส่วนที่ 3: ระบบ Slot ESP (เวอร์ชันปลดล็อคข้อจำกัด หาเจอแน่นอน)
task.spawn(function()
    local function GetSlotText(entity)
        local slotsFolder = entity:FindFirstChild("Slots", true) or entity:FindFirstChild("slots", true)
        
        if not slotsFolder then
            local plr = game.Players:GetPlayerFromCharacter(entity)
            if plr then slotsFolder = plr:FindFirstChild("Slots", true) or plr:FindFirstChild("slots", true) end
        end

        if not slotsFolder then return nil end

        local slotsData = {}

        for i = 1, 10 do
            local s = slotsFolder:FindFirstChild("Slot" .. i) or slotsFolder:FindFirstChild("Slot " .. i)
            if s then
                local success, rawValue = pcall(function() return s.Value end)
                if success then
                    local val = "None"
                    if typeof(rawValue) == "Instance" then
                        val = rawValue.Name
                    elseif rawValue ~= nil then
                        val = tostring(rawValue)
                    end
                    
                    if val == "" or val == "nil" or val:match("^%s*$") then val = "None" end
                    table.insert(slotsData, "Slot " .. i .. " : " .. val)
                end
            end
        end

        if #slotsData == 0 then return nil end

        local line1, line2 = {}, {}
        for i, text in ipairs(slotsData) do
            if i <= 2 then table.insert(line1, text) else table.insert(line2, text) end
        end

        local finalText = table.concat(line1, "   ")
        if #line2 > 0 then finalText = finalText .. "\n" .. table.concat(line2, "   ") end

        local equippedTool = entity:FindFirstChildOfClass("Tool")
        if equippedTool then
            finalText = finalText .. "\n[ Holding : " .. equippedTool.Name .. " ]"
        end

        return finalText
    end

    local function UpdateSlotESP(target, text)
        if not target or not target.Parent then return end
        
        local root = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
        if not root then return end

        local bg = root:FindFirstChild("ESP_Slot_BG") or Instance.new("BillboardGui")
        bg.Name = "ESP_Slot_BG"
        bg.Size = UDim2.new(0, 300, 0, 70) 
        bg.AlwaysOnTop = true
        
        bg.ExtentsOffsetWorldSpace = Vector3.new(0, -4.5, 0)
        bg.StudsOffset = Vector3.new(0, 0, 0) 
        
        local txt = bg:FindFirstChild("NameLabel") or Instance.new("TextLabel")
        txt.Name = "NameLabel"
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = text
        txt.TextColor3 = Color3.fromRGB(255, 255, 255)
        txt.Font = Enum.Font.SourceSansBold
        txt.TextSize = 14
        txt.TextWrapped = true
        txt.TextStrokeTransparency = 0.6
        
        txt.AnchorPoint = Vector2.new(0.5, 0)
        txt.Position = UDim2.new(0.5, 0, 0, 0)
        
        txt.Parent = bg
        bg.Parent = root
    end

    while task.wait(1) do
        if SlotEspToggle and SlotEspToggle.Value then
            pcall(function()
                -- สแกนผู้เล่น
                for _, plr in ipairs(game.Players:GetPlayers()) do
                    if plr.Character and plr ~= game.Players.LocalPlayer then
                        local char = plr.Character
                        
                        -- 🔥 เงื่อนไขใหม่: เช็คว่าในตัวมี Weapon ไหม
                        if char:FindFirstChild("Weapon", true) then
                            -- ถ้าเป็นฆาตกร (มี Weapon) ให้ลบป้ายสล็อตทิ้งเลย
                            local root = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart or char:FindFirstChildWhichIsA("BasePart")
                            if root and root:FindFirstChild("ESP_Slot_BG") then root.ESP_Slot_BG:Destroy() end
                        else
                            -- ถ้าไม่ใช่ฆาตกร ถึงจะดึงสล็อตมาโชว์
                            local text = GetSlotText(char)
                            if text then
                                UpdateSlotESP(char, text)
                            else
                                local root = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart or char:FindFirstChildWhichIsA("BasePart")
                                if root and root:FindFirstChild("ESP_Slot_BG") then root.ESP_Slot_BG:Destroy() end
                            end
                        end
                    end
                end

                -- สแกนบอท
                local playersFolder = workspace:FindFirstChild("Players") or (workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Players"))
                if playersFolder then
                    for _, bot in ipairs(playersFolder:GetChildren()) do
                        if bot:IsA("Model") and bot ~= game.Players.LocalPlayer.Character then
                            
                            -- 🔥 เงื่อนไขใหม่: เช็คบอทว่ามี Weapon ไหม
                            if bot:FindFirstChild("Weapon", true) then
                                local root = bot:FindFirstChild("HumanoidRootPart") or bot.PrimaryPart or bot:FindFirstChildWhichIsA("BasePart")
                                if root and root:FindFirstChild("ESP_Slot_BG") then root.ESP_Slot_BG:Destroy() end
                            else
                                local text = GetSlotText(bot)
                                if text then
                                    UpdateSlotESP(bot, text)
                                else
                                    local root = bot:FindFirstChild("HumanoidRootPart") or bot.PrimaryPart or bot:FindFirstChildWhichIsA("BasePart")
                                    if root and root:FindFirstChild("ESP_Slot_BG") then root.ESP_Slot_BG:Destroy() end
                                end
                            end
                            
                        end
                    end
                end
            end)
        end
    end
end)

