-- ฟังก์ชันหลักสำหรับ Add/Remove
local function fireObjectAction(actionType)
    local char = Players.LocalPlayer.Character
    if not char then return end

    local _, modelAnimRemote = getRemotes()
    if not modelAnimRemote then return end

    local uuidsToFire = {}
    local partsToFire = {}

    -- เช็ค UUID ว่าเลือก All ไหม
    if selectedCustomUUIDs["All"] then
        for _, uuid in pairs(ItemNameToUUID) do
            table.insert(uuidsToFire, uuid)
        end
    else
        for name, isSelected in pairs(selectedCustomUUIDs) do
            if isSelected and ItemNameToUUID[name] then
                table.insert(uuidsToFire, ItemNameToUUID[name])
            end
        end
    end

    -- เช็ค Body Parts ว่าเลือก All ไหม
    if selectedCustomParts["All"] then
        for _, part in ipairs(baseBodyPartsList) do
            table.insert(partsToFire, part)
        end
    else
        for partName, isSelected in pairs(selectedCustomParts) do
            if isSelected and partName ~= "All" then
                table.insert(partsToFire, partName)
            end
        end
    end

    if #uuidsToFire == 0 or #partsToFire == 0 then
        -- แจ้งเตือนแบบ Fluent ถ้าลืมเลือก
        Fluent:Notify({
            Title = "Warning",
            Content = "select body part first",
            Duration = 3
        })
        return
    end

    local count = 0
    for _, uuid in ipairs(uuidsToFire) do
        for _, part in ipairs(partsToFire) do
            modelAnimRemote:FireServer(actionType, uuid, part, char)
            count = count + 1
        end
    end

    local actionName = actionType == 0 and "Added" or "Removed"
    Fluent:Notify({
        Title = "Success",
        Content = actionName .. " " .. count .. " objects!",
        Duration = 3
    })
end

