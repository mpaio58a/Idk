local attackGui = nil
do
    Tabs.Misc:AddButton({ Title = "Revive", Callback = function() 
        game:GetService("ReplicatedStorage").Events.Leave:FireServer() 
        game:GetService("ReplicatedStorage").Events.Join:FireServer() 
    end })
    Tabs.Misc:AddButton({ Title = "Leave", Callback = function() game:GetService("ReplicatedStorage").Events.Leave:FireServer() end })
    Tabs.Misc:AddButton({ Title = "God Mode", Callback = function() 
        game:GetService("ReplicatedStorage").Events.Join:FireServer() 
        task.wait(0.1) 
        game:GetService("ReplicatedStorage").Events.Leave:FireServer() 
    end })

    -- Anti Trap Toggle (Updated with Hide/Restore Logic)
    local AntiTrapToggle = Tabs.Misc:AddToggle("AntiTrap", {
        Title = "Anti Trap", 
        Description = "Walking into traps will have no effect while this script is enabled.", 
        Default = false 
    })

    AntiTrapToggle:OnChanged(function()
        if AntiTrapToggle.Value then
            -- [ ON: Remove all 'Center' parts ]
            pcall(function()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and obj.Name == "Center" then
                        table.insert(_G.HiddenCenterParts, {
                            parent = obj.Parent,
                            part = obj
                        })
                        obj.Parent = nil
                    end
                end
            end)
            print("Anti Trap: Enabled")
        else
            -- [ OFF: Restore all 'Center' parts ]
            pcall(function()
                if _G.HiddenCenterParts and #_G.HiddenCenterParts > 0 then
                    for _, data in pairs(_G.HiddenCenterParts) do
                        if data.part and data.parent then
                            data.part.Parent = data.parent
                        end
                    end
                    _G.HiddenCenterParts = {} -- ล้างตารางหลังจากคืนค่า
                end
            end)
            print("Anti Trap: Disabled")
        end
    end)

    local AttackToggle = Tabs.Misc:AddToggle("AttackBtnSwitch", {Title = "Show Custom Attack Button", Default = false })
    AttackToggle:OnChanged(function()
        if AttackToggle.Value then
            if not attackGui then
                attackGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
                local btn = Instance.new("TextButton", attackGui)
                local c = Instance.new("UICorner", btn)
                btn.Size = UDim2.new(0, 120, 0, 50)
                btn.Position = UDim2.new(0.5, -60, 0.8, 0)
                btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                btn.Text = "ATTACK"
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.Font = Enum.Font.SourceSansBold
                btn.TextSize = 20
                btn.Draggable = true
                c.CornerRadius = UDim.new(0, 12)
                btn.MouseButton1Click:Connect(function() game:GetService("ReplicatedStorage").Events.Attack:FireServer() end)
            end
            attackGui.Enabled = true
        else
            if attackGui then attackGui.Enabled = false end
        end
    end)
end

