            _G.PlayerEspEnabled = false
            _G.ItemEspEnabled = false
            _G.TrapEspEnabled = false

            -- คืนค่าพาร์ท Center ถ้าปิด UI ไปดื้อๆ
            if _G.HiddenCenterParts and #_G.HiddenCenterParts > 0 then
                for _, data in pairs(_G.HiddenCenterParts) do
                    if data.part and data.parent then data.part.Parent = data.parent end
                end
                _G.HiddenCenterParts = {}
            end
            break
        end
    end
 end)