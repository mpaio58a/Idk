--// ⚙️ ฟังก์ชันจัดการฟิสิกส์และการสลับกล้อง (วนลูปใช้)
local function DoPhysicsFling(TargetPlayer)
    if not TargetPlayer or not TargetPlayer.Character then return end

    local TargetRoot = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local TargetHum = TargetPlayer.Character:FindFirstChildOfClass("Humanoid")

    local Character = LocalPlayer.Character
    local Root = Character and Character:FindFirstChild("HumanoidRootPart")
    local Hum = Character and Character:FindFirstChildOfClass("Humanoid")

    if not TargetRoot or not TargetHum or not Root or not Hum then return end

    local OldPos = Root.CFrame
    local OldFPDH = workspace.FallenPartsDestroyHeight
    workspace.FallenPartsDestroyHeight = -50000

    -- ✨ เปลี่ยนมุมกล้องไปที่เหยื่อ
    workspace.CurrentCamera.CameraSubject = TargetHum

    Hum.PlatformStand = true
    local BV = Instance.new("BodyVelocity")
    BV.Parent = Root
    BV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    BV.Velocity = Vector3.new(0, 0, 0)

    local StartTime = tick()
    local Connection
    local HasFlung = false

    Connection = RunService.Heartbeat:Connect(function()
        if tick() - StartTime > 3 or not TargetPlayer.Character or not Character.Parent or HasFlung then
            if Connection then Connection:Disconnect() end
            return
        end

        -- เช็คเป้าหมายปลิว
        if TargetRoot.AssemblyLinearVelocity.Magnitude > 250 then
            HasFlung = true
            return
        end

        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end

        local ChaosRot = CFrame.Angles(
            math.rad(math.random(-36000, 36000)), 
            math.rad(math.random(-36000, 36000)), 
            math.rad(math.random(-36000, 36000))
        )

        Root.CFrame = TargetRoot.CFrame * ChaosRot
        Root.AssemblyLinearVelocity = Vector3.new(9e30, 9e30, 9e30)
        Root.AssemblyAngularVelocity = Vector3.new(9e30, 9e30, 9e30)
    end)

    local elapsed = 0
    while elapsed < 3 do
        if HasFlung or not TargetPlayer.Character or not TargetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            break
        end
        elapsed = elapsed + task.wait(0.1)
    end

    -- 🧹 Cleanup คืนค่า
    if Connection then Connection:Disconnect() end
    if BV then BV:Destroy() end
    Hum.PlatformStand = false

    workspace.CurrentCamera.CameraSubject = Hum
    workspace.FallenPartsDestroyHeight = OldFPDH

    Root.CFrame = OldPos
    Root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    Root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

