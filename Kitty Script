-- [[ 3.5 ระบบอัพเดท Distance แบบ Real-Time (ลื่นไหลไม่กระตุก) ]]
-- ==========================================================
RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local myPos = LocalPlayer.Character.HumanoidRootPart.Position

    for target, data in pairs(ActiveESPs) do
        -- เช็คว่าถ้าเป้าหมายตาย, หายไป หรือปิด ESP ป้ายชื่อไปแล้ว ให้ลบออกจากตาราง
        if not target or not target.Parent or not data.Root or not data.Root.Parent or not data.NameLabel.Parent then
            ActiveESPs[target] = nil
            continue
        end

        -- คำนวณระยะทางและอัพเดทข้อความเฟรมต่อเฟรม (เรียลไทม์)
        local dist = math.floor((myPos - data.Root.Position).Magnitude)
        local finalText = ""
        
        if NameToggle.Value then finalText = data.BaseName end
        if DistanceToggle.Value then
            if finalText ~= "" then
                finalText = finalText .. " [" .. tostring(dist) .. "m]"
            else
                finalText = "[" .. tostring(dist) .. "m]"
            end
        end

        data.NameLabel.Text = finalText
        data.NameLabel.Visible = (NameToggle.Value or DistanceToggle.Value)
    end
end)

